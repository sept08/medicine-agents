#!/bin/sh
set -eu

supports_required_python() {
  "$1" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1
}

if command -v python3 >/dev/null 2>&1 && supports_required_python python3; then
  PYTHON_BIN=python3
elif command -v python >/dev/null 2>&1 && supports_required_python python; then
  PYTHON_BIN=python
else
  echo "Python 3.11+ is required to run the repository privacy check." >&2
  exit 1
fi

exec "$PYTHON_BIN" scripts/check_sensitive_content.py
